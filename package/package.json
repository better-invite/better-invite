{
	"name": "better-invite",
	"version": "0.0.0-semantically-released",
	"description": "A better-auth plugin that allows you to invite users to your app.",
	"type": "module",
	"license": "MIT",
	"homepage": "https://www.better-invite.com",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/better-invite/better-invite.git"
	},
	"keywords": [
		"better-auth",
		"invite",
		"invitation",
		"better-auth-invite",
		"better-auth-plugin",
		"better-auth-invite-plugin",
		"better-invite-plugin",
		"better-invite",
		"invite-plugin"
	],
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false,
	"scripts": {
		"test": "vitest",
		"coverage": "vitest run --coverage",
		"build": "tsdown"
	},
	"files": [
		"dist"
	],
	"main": "./dist/index.mjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"author": "Sandy",
	"packageManager": "pnpm@10.28.0",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"typesVersions": {
		"*": {
			"*": [
				"./dist/index.d.mts"
			]
		}
	},
	"dependencies": {
		"@better-auth/utils": "^0.3.0",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^25.0.8",
		"@vitest/coverage-v8": "4.0.17",
		"better-auth": "^1.6.2",
		"better-sqlite3": "^12.6.0",
		"tsdown": "^0.21.7",
		"typescript": "^5.9.3",
		"vitest": "^4.0.17"
	},
	"peerDependencies": {
		"better-auth": "^1.6.2"
	},
	"onlyBuiltDependencies": [
		"better-sqlite3"
	],
	"release": {
		"branches": [
			"main",
			{
				"name": "beta",
				"prerelease": "beta"
			}
		],
		"plugins": [
			"@semantic-release/commit-analyzer",
			"@semantic-release/release-notes-generator",
			"@semantic-release/npm",
			"@semantic-release/github"
		]
	}
}
